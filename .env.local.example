# Get a free WalletConnect Project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Get a free Basescan API key at https://basescan.org/myapikey
# Required for: deployed contracts count, detailed tx history
# Optional: tx count falls back to on-chain nonce if omitted
NEXT_PUBLIC_BASESCAN_API_KEY=your_basescan_api_key_here
